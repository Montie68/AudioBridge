<Window x:Class="AudioBridgeUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AudioBridge"
        Width="400" Height="520"
        MinWidth="360" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Common brushes -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4690D6"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="SliderTrackBrush" Color="#555555"/>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Button style -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5AA0E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A80C6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox style for dark theme -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Slider style -->
        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header / Status Bar -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator -->
                <Ellipse Grid.Column="0"
                         Width="12" Height="12"
                         Fill="{Binding StatusIndicatorBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"/>

                <!-- Status text -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- Start/Stop button -->
                <Button Grid.Column="2"
                        Content="{Binding ToggleBridgeButtonText}"
                        Command="{Binding ToggleBridgeCommand}"
                        Style="{StaticResource AccentButton}"/>
            </Grid>
        </Border>

        <!-- Device List -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8">
            <ItemsControl ItemsSource="{Binding Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="8,4"
                                Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Bridge toggle checkbox -->
                                <CheckBox Grid.Row="0" Grid.Column="0"
                                          IsChecked="{Binding IsBridged}"
                                          IsEnabled="{Binding IsCheckboxEnabled}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox" BasedOn="{StaticResource DarkCheckBox}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                    <Setter Property="ToolTip" Value="This is the default audio output. AudioBridge captures from it — it can't be a bridge target."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>

                                <!-- Status indicator dot -->
                                <Ellipse Grid.Row="0" Grid.Column="1"
                                         Width="8" Height="8"
                                         Fill="{Binding StatusBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>

                                <!-- Device name + Source badge -->
                                <StackPanel Grid.Row="0" Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DeviceName}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Border Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="#3A5A7A"
                                            CornerRadius="3"
                                            Padding="4,1"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            ToolTip="This is the default audio output. AudioBridge captures from it — it can't be a bridge target.">
                                        <TextBlock Text="Source"
                                                   Foreground="#90C8F0"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>

                                <!-- Volume slider row -->
                                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                      Margin="24,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Slider Grid.Column="0"
                                            Value="{Binding Volume, Mode=TwoWay}"
                                            IsEnabled="{Binding IsVolumeEnabled}"
                                            Style="{StaticResource VolumeSlider}"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Volume, StringFormat={}{0}%}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Width="36"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Settings Section -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          Content="Start with Windows"
                          IsChecked="{Binding StartWithWindows}"
                          Style="{StaticResource DarkCheckBox}"/>

                <Button Grid.Column="1"
                        Content="Refresh"
                        Command="{Binding RefreshDevicesCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="12,6"/>
            </Grid>
        </Border>
    </Grid>
</Window>
